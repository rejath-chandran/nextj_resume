generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model PersonalInfo {
  id              Int             @id @default(autoincrement())
  fullName        String
  email           String
  phone           String?
  location        String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  summary         String?
  title           String?
  resumeName      String?         @map("resume_name")
  userId          String?         @map("user_id")
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  experiences     Experience[]
  education       Education[]
  skills          Skill[]
  projects        Project[]
  certifications  Certification[]

  @@index([userId])
  @@map("personal_info")
}

/* ----------------------------- Better Auth ----------------------------- */

model User {
  id            String           @id @default(cuid())
  name          String
  email         String           @unique
  emailVerified Boolean          @default(false)
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sessions      Session[]
  accounts      Account[]
  personalInfos PersonalInfo[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Experience {
  id              Int          @id @default(autoincrement())
  personalInfoId  Int
  company         String
  position        String
  location        String?
  startDate       String
  endDate         String?
  currentJob      Boolean      @default(false)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  personalInfo    PersonalInfo @relation(fields: [personalInfoId], references: [id], onDelete: Cascade)

  @@index([personalInfoId])
  @@map("experiences")
}

model Education {
  id              Int          @id @default(autoincrement())
  personalInfoId  Int
  institution     String
  degree          String
  fieldOfStudy    String?
  location        String?
  graduationDate  String?
  gpa             String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  personalInfo    PersonalInfo @relation(fields: [personalInfoId], references: [id], onDelete: Cascade)

  @@index([personalInfoId])
  @@map("education")
}

model Skill {
  id                Int          @id @default(autoincrement())
  personalInfoId    Int
  category          String
  skillName         String
  proficiencyLevel  String       @default("intermediate")
  createdAt         DateTime     @default(now())
  personalInfo      PersonalInfo @relation(fields: [personalInfoId], references: [id], onDelete: Cascade)

  @@index([personalInfoId])
  @@map("skills")
}

model Project {
  id              Int          @id @default(autoincrement())
  personalInfoId  Int
  name            String
  description     String?
  technologies    String?
  projectUrl      String?
  githubUrl       String?
  startDate       String?
  endDate         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  personalInfo    PersonalInfo @relation(fields: [personalInfoId], references: [id], onDelete: Cascade)

  @@index([personalInfoId])
  @@map("projects")
}

model Certification {
  id                   Int          @id @default(autoincrement())
  personalInfoId       Int
  name                 String
  issuingOrganization  String
  issueDate            String?
  expirationDate       String?
  credentialUrl        String?
  createdAt            DateTime     @default(now())
  personalInfo         PersonalInfo @relation(fields: [personalInfoId], references: [id], onDelete: Cascade)

  @@index([personalInfoId])
  @@map("certifications")
}
